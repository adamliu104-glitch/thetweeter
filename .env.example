# Copy this file to ".env" and adjust the values for your machine.
#   cp .env.example .env
#
# On Render, PORT and DATABASE_URL are provided for you automatically,
# so you do NOT commit a real .env file (see .gitignore).

# The port the server listens on. Locally we default to 3000.
PORT=3000

# Postgres connection string.
# Local example below — change "boontweet" if your database has another name:
DATABASE_URL=postgres://localhost:5432/boontweet

# Secret used to sign the login session cookie.
# Use a long, random string in production.
SESSION_SECRET=dev-secret-change-me
